# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# ===== Database Configuration =====
# PostgreSQL example (REQUIRED for production)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fitness_analyzer
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===== Authentication =====
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== File Storage =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=csv,xlsx,jpg,png,jpeg

# ===== Machine Learning Models =====
ML_MODELS_PATH=./ml_models
NLP_MODEL_NAME=bert-base-uncased
NLP_MODEL_DEVICE=cpu
CV_MODEL_NAME=yolov8
TS_MODEL_NAME=prophet

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== Optional External Services =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=